<main aria-label="Frontpage content">
    <div class="page-container">

        <section aria-label="Welcome picture">
            <img 
                src="/images/movie.png" 
                alt="Four people watching movies together" width="1000px">
        </section>

        <section aria-labelledby="newest">
            <h2 id="newest-movies">Newest movies</h2>
        </section>

        <div class="movie-container">
        {{#each newestMovies}}
            <div class="movie-card">
                <h2>{{this.title}}</h2>
                <img src="{{this.image}}" alt="{{this.alt}}" width="100%">

                <p><strong>Director:</strong> {{this.director}}</p>
                <p><strong>Release date:</strong> {{this.releaseDate}}</p>
                <p><strong>Genres:</strong> {{this.genres}}</p>
                <p><strong>Rating:</strong> {{this.rating}}</p>
            </div>
        {{/each}}
</div>

    </div>
</main>